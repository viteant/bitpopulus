---
interface Props {
    badge: string
    titleBefore: string
    titleHighlight: string
    description: string
}

const { badge, titleBefore, titleHighlight, description } = Astro.props
---

<section class="px-8 py-20 md:py-32 bg-white border-b-4 border-on-surface">
    <div class="max-w-4xl mx-auto">
    <span class="inline-block px-4 py-1 bg-secondary-container border-2 border-on-surface font-black text-xs uppercase tracking-[0.3em] mb-8 rotate-[-1deg] hard-shadow">
      {badge}
    </span>

        <h1 class="text-6xl md:text-8xl font-black tracking-tighter mb-10 italic">
            {titleBefore} <span class="text-primary">{titleHighlight}</span>
        </h1>

        <p class="text-xl md:text-3xl font-bold text-zinc-600 leading-tight">
            {description}
        </p>
    </div>
</section>
