---
interface Props {
    badge: string
    title: string
    buttonText: string
}

const { badge, title, buttonText } = Astro.props
---

<section class="px-8 py-32 bg-white flex flex-col items-center">
    <div class="max-w-4xl text-center">
        <div class="inline-block px-4 py-1 bg-secondary-container border-2 border-on-surface font-black text-sm mb-8 rotate-1">
            {badge}
        </div>

        <h2 class="text-5xl md:text-7xl font-black mb-12 leading-tight">{title}</h2>

        <button class="signature-gradient text-white text-2xl font-black px-12 py-6 border-4 border-on-surface hard-shadow-lg btn-press transition-all">
            {buttonText}
        </button>
    </div>
</section>