---
interface InfoItem {
    label: string
    value: string
    icon: string
    iconBgClass: string
    href?: string
}

interface Props {
    items: InfoItem[]
}

const { items } = Astro.props
---

<div class="grid gap-6">
    {items.map((item) => {
        const Tag = item.href ? 'a' : 'div'

        return (
                <Tag
                        href={item.href}
                        class="bg-surface-container-high border-2 border-on-surface p-6 rounded-xl shadow-[6px_6px_0px_0px_rgba(23,28,35,1)] flex items-center gap-6 group hover:-translate-y-1 transition-transform"
                >
                    <div class={`w-14 h-14 flex items-center justify-center rounded-full border-2 border-on-surface ${item.iconBgClass}`}>
          <span class="material-symbols-outlined text-on-surface font-bold text-2xl">
            {item.icon}
          </span>
                    </div>

                    <div>
                        <p class="text-label-md font-black text-on-surface-variant uppercase tracking-widest">
                            {item.label}
                        </p>
                        <p class="text-xl font-bold">{item.value}</p>
                    </div>
                </Tag>
        )
    })}
</div>