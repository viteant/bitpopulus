---
interface SocialItem {
    label: string
    icon: string
    href: string
    hoverClass: string
}

interface Props {
    title: string
    items: SocialItem[]
}

const { title, items } = Astro.props
---

<div class="mt-8">
    <h3 class="text-label-md font-black uppercase tracking-[0.2em] mb-6 text-on-surface-variant">
        {title}
    </h3>

    <div class="grid grid-cols-3 gap-4">
        {items.map((item) => (
                <a
                        class={`bg-surface border-2 border-on-surface p-4 flex flex-col items-center justify-center rounded-xl shadow-[4px_4px_0px_0px_rgba(23,28,35,1)] transition-colors group ${item.hoverClass}`}
                        href={item.href}
                        target="_blank"
                        rel="noreferrer"
                >
                    <span class="material-symbols-outlined text-3xl mb-2">{item.icon}</span>
                    <span class="text-xs font-black uppercase">{item.label}</span>
                </a>
        ))}
    </div>
</div>