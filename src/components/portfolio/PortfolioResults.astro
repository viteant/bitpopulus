---
interface StatItem {
    value: string
    label: string
    watermark: string
    valueClass: string
}

interface Testimonial {
    quote: string
    name: string
    role: string
    avatarSrc: string
    avatarAlt: string
}

interface Props {
    stats: StatItem[]
    testimonial: Testimonial
}

const { stats, testimonial } = Astro.props
---

<section class="bg-black text-white py-24 px-8 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
            {stats.map((stat) => (
                    <div class="relative">
                        <div class={`text-8xl font-black mb-4 ${stat.valueClass}`}>{stat.value}</div>
                        <p class="text-xl font-bold uppercase tracking-tighter max-w-[200px]">{stat.label}</p>
                        <div class="absolute -right-10 top-0 text-white/10 text-9xl font-black select-none">
                            {stat.watermark}
                        </div>
                    </div>
            ))}
        </div>

        <div class="mt-32 p-12 bg-white text-black border-4 border-[#FF7A00] hard-shadow relative">
      <span class="material-symbols-outlined text-6xl text-primary-container absolute -top-8 -left-4 bg-white px-2">
        format_quote
      </span>

            <p class="text-2xl md:text-4xl font-black leading-tight mb-8">
                "{testimonial.quote}"
            </p>

            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-black rounded-full overflow-hidden border-2 border-black">
                    <img
                            src={testimonial.avatarSrc}
                            alt={testimonial.avatarAlt}
                            class="w-full h-full object-cover"
                    />
                </div>

                <div>
                    <div class="font-black uppercase">{testimonial.name}</div>
                    <div class="text-sm font-bold text-on-surface-variant uppercase tracking-widest">
                        {testimonial.role}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>