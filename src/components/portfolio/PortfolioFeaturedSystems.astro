---
interface FeaturedMain {
    title: string
    description: string
    imageSrc: string
    imageAlt: string
    tags: string[]
}

interface FeaturedSide {
    title: string
    description: string
    imageSrc: string
    imageAlt: string
    cta: string
}

interface Props {
    title: string
    main: FeaturedMain
    side: FeaturedSide
}

const { title, main, side } = Astro.props
---

<section class="px-8 py-20 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-end mb-16">
            <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase">
                {title.split('\n').map((line: string) => (
                        <>
                            {line}
                            <br />
                        </>
                ))}
            </h2>

            <div class="hidden md:block w-48 h-2 bg-black"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
            <div class="md:col-span-8 group relative bg-white border-4 border-black p-8 xl:rounded-xl hard-shadow-lg transition-all hover:translate-x-1 hover:translate-y-1 hover:shadow-none">
                <div class="flex flex-col h-full justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-12">
                            <h3 class="text-4xl font-black uppercase">{main.title}</h3>
                            <span class="material-symbols-outlined text-4xl group-hover:rotate-45 transition-transform">
                arrow_outward
              </span>
                        </div>

                        <div class="aspect-[16/7] w-full overflow-hidden border-4 border-black mb-8">
                            <img
                                    src={main.imageSrc}
                                    alt={main.imageAlt}
                                    class="w-full h-full object-cover"
                            />
                        </div>

                        <p class="text-xl font-bold mb-6 max-w-xl">{main.description}</p>
                    </div>

                    <div class="flex gap-4 flex-wrap">
                        {main.tags.map((tag) => (
                                <span class="px-3 py-1 border-2 border-black text-xs font-black uppercase">
                {tag}
              </span>
                        ))}
                    </div>
                </div>
            </div>

            <div class="md:col-span-4 group bg-secondary-container border-4 border-black p-8 xl:rounded-xl hard-shadow-lg transition-all hover:translate-x-1 hover:translate-y-1 hover:shadow-none">
                <div class="flex flex-col h-full">
                    <h3 class="text-3xl font-black uppercase mb-6">{side.title}</h3>

                    <div class="aspect-square w-full overflow-hidden border-4 border-black mb-6">
                        <img
                                src={side.imageSrc}
                                alt={side.imageAlt}
                                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                        />
                    </div>

                    <p class="text-lg font-bold mb-auto">{side.description}</p>

                    <div class="mt-8 pt-6 border-t-2 border-black/20">
                        <span class="text-sm font-black uppercase">{side.cta}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>