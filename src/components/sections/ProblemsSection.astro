---
interface ProblemItem {
    title: string;
    description: string;
    icon?: string;
    accentClass?: string;
    rotateClass?: string;
}

interface Props {
    title: string;
    subtitle: string;
    badge?: string;
    items: ProblemItem[];
}

const {
    title,
    subtitle,
    badge = "WE FIX THIS.",
    items,
} = Astro.props as Props;
---

<section class="bg-black px-8 py-24 text-white">
    <div class="mx-auto max-w-350">
        <div class="mb-16 flex flex-col justify-between gap-8 md:flex-row md:items-end">
            <div>
                <h2 class="text-5xl font-black uppercase tracking-tighter italic md:text-7xl">
                    {title}
                </h2>
                <p class="mt-4 max-w-2xl text-2xl font-bold text-zinc-400">
                    {subtitle}
                </p>
            </div>

            <div class="rotate-3 border-4 border-white bg-white p-4 text-xl font-black text-black">
                {badge}
            </div>
        </div>

        <div class="grid grid-cols-1 gap-10 lg:grid-cols-3">
            {items.map((item) => (
                    <div
                            class:list={[
                                "border-4 border-white bg-white p-8 text-black transition-transform neubrutalism-shadow-secondary hover:rotate-0",
                                item.rotateClass ?? "",
                            ]}
                    >
                        {item.icon && (
                                <span
                                        class:list={[
                                            "material-symbols-outlined mb-8 !text-3xl md:!text-5xl",
                                            item.accentClass ?? "text-violet-600",
                                        ]}
                                >
              {item.icon}
            </span>
                        )}

                        <h3 class="mb-4 text-3xl font-black uppercase">{item.title}</h3>
                        <p class="font-bold leading-relaxed text-zinc-600">
                            {item.description}
                        </p>
                    </div>
            ))}
        </div>
    </div>
</section>