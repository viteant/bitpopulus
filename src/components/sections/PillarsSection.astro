---
interface FeatureCard {
    label: string;
    title: string;
    description: string;
    bullets: string[];
    imageSrc: string;
    imageAlt: string;
}

interface BrandGrowthCard {
    title: string;
    description: string;
    bullets: string[];
    cta: string;
}

interface AiCard {
    title: string;
    description: string;
    tags: string[];
}

interface EngineeringCard {
    title: string;
    description: string;
    stack: string[];
}

interface Props {
    title: string;
    feature: FeatureCard;
    brandGrowth: BrandGrowthCard;
    ai: AiCard;
    engineering: EngineeringCard;
}

const { title, feature, brandGrowth, ai, engineering } = Astro.props;
---

<section class="bg-zinc-100 px-8 py-24">
    <div class="mx-auto max-w-screen-2xl">
        <h2 class="mb-16 text-4xl font-black italic tracking-tight underline decoration-secondary-container decoration-8 md:text-6xl">
            {title}
        </h2>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
            <div class="flex flex-col gap-10 rounded-xl border-4 border-zinc-900 bg-white p-12 md:flex-row lg:col-span-2 neubrutalism-shadow">
                <div class="md:w-1/2">
          <span class="mb-6 inline-block bg-violet-100 px-4 py-1 text-xs font-black uppercase text-violet-700">
            {feature.label}
          </span>

                    <h3 class="mb-6 text-4xl font-black">{feature.title}</h3>
                    <p class="mb-8 text-lg font-medium leading-relaxed text-zinc-600">
                        {feature.description}
                    </p>

                    <ul class="space-y-3 text-sm font-bold">
                        {feature.bullets.map((bullet) => (
                                <li class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-violet-600">check_circle</span>
                                    {bullet}
                                </li>
                        ))}
                    </ul>
                </div>

                <div class="overflow-hidden rounded-xl border-4 border-zinc-900 bg-zinc-50 md:w-1/2 neubrutalism-shadow-small">
                    <img src={feature.imageSrc} alt={feature.imageAlt} class="h-full w-full object-cover" />
                </div>
            </div>

            <div class="flex flex-col justify-between rounded-xl border-4 border-zinc-900 bg-[#FFD60A] p-10 neubrutalism-shadow">
                <div>
                    <h3 class="mb-6 text-3xl font-black">{brandGrowth.title}</h3>
                    <p class="mb-6 font-bold leading-snug text-zinc-800">{brandGrowth.description}</p>

                    <ul class="mb-8 space-y-4">
                        {brandGrowth.bullets.map((bullet) => (
                                <li class="flex items-start gap-3">
                                    <span class="material-symbols-outlined mt-0.5 font-black">stat_3</span>
                                    <p class="text-sm font-bold">{bullet}</p>
                                </li>
                        ))}
                    </ul>
                </div>

                <div class="cursor-pointer rounded-lg border-4 border-zinc-900 bg-white p-4 text-center font-black uppercase tracking-widest transition-colors hover:bg-zinc-900 hover:text-white neubrutalism-shadow-small hover:shadow-none">
                    {brandGrowth.cta}
                </div>
            </div>

            <div class="flex flex-col justify-between rounded-xl border-4 border-zinc-900 bg-zinc-900 p-10 text-white neubrutalism-shadow">
                <span class="material-symbols-outlined mb-6 !text-6xl text-tertiary-fixed">neurology</span>

                <div>
                    <h3 class="mb-4 text-3xl font-black">{ai.title}</h3>
                    <p class="mb-6 font-medium leading-relaxed text-zinc-400">{ai.description}</p>

                    <div class="flex flex-wrap gap-2">
                        {ai.tags.map((tag) => (
                                <span class="rounded border border-zinc-700 bg-zinc-800 px-3 py-1 text-xs font-bold">
                {tag}
              </span>
                        ))}
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-10 rounded-xl border-4 border-zinc-900 bg-gradient-to-br from-zinc-50 to-zinc-200 p-12 lg:col-span-2 neubrutalism-shadow">
                <div class="w-full">
                    <h3 class="mb-6 text-4xl font-black">{engineering.title}</h3>
                    <p class="mb-8 text-lg font-medium text-zinc-600">{engineering.description}</p>

                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:md:grid-cols-4">
                        {engineering.stack.map((item) => (
                                <div class="rounded-lg border-2 border-zinc-900 bg-white p-4 text-center font-black neubrutalism-shadow-small">
                                    {item}
                                </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>