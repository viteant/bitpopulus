---
interface Props {
    title: string
    description: string
    inputPlaceholder: string
    buttonText: string
    formAction?: string
    formMethod?: string
}

const {
    title,
    description,
    inputPlaceholder,
    buttonText,
    formAction = '#',
    formMethod = 'post'
} = Astro.props
---

<div class="mt-16 flex flex-wrap items-center gap-4 p-8 border-4 border-zinc-900 bg-secondary-container neubrutal-shadow">
    <div class="flex-1">
        <h4 class="text-xl font-black uppercase tracking-tighter">{title}</h4>
        <p class="font-bold opacity-80">{description}</p>
    </div>

    <form action={formAction} method={formMethod} class="flex gap-2 w-full md:w-auto">
        <input
                class="flex-1 md:w-64 border-2 border-zinc-900 rounded-sm px-4 py-2 outline-none"
                placeholder={inputPlaceholder}
                type="email"
                name="email"
        />

        <button class="bg-zinc-900 text-white font-black uppercase px-6 py-2 border-2 border-zinc-900 neubrutal-shadow-sm hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" type="submit">
            {buttonText}
        </button>
    </form>
</div>