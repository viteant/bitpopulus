---
interface Figure {
    label: string
    caption: string
}

interface Props {
    imageSrc: string
    imageAlt: string
    figure: Figure
}

const { imageSrc, imageAlt, figure } = Astro.props
---

<section class="relative mb-20">
    <div class="relative group">
        <div class="absolute -inset-4 bg-[#FF7A00] -z-10 rotate-1"></div>

        <div class="border-4 border-zinc-900 neubrutal-shadow overflow-hidden rounded-xl bg-zinc-950">
            <img
                    src={imageSrc}
                    alt={imageAlt}
                    class="w-full h-[500px] object-cover mix-blend-screen opacity-90 transition-transform duration-700 group-hover:scale-105"
            />
        </div>

        <div class="absolute bottom-6 left-6 bg-white border-2 border-zinc-900 p-4 neubrutal-shadow-sm max-w-sm hidden md:block">
            <p class="text-xs font-black uppercase tracking-widest text-zinc-500 mb-1">{figure.label}</p>
            <p class="text-sm font-bold">{figure.caption}</p>
        </div>
    </div>
</section>