---
interface FeatureItem {
    number: string
    title: string
    description: string
}

interface Props {
    coreLabel: string
    title: string
    items: FeatureItem[]
    imageSrc: string
    imageAlt: string
}

const { coreLabel, title, items, imageSrc, imageAlt } = Astro.props
---

<div class="max-w-7xl mx-auto px-8 overflow-x-hidden">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-6">
            <div class="relative inline-block">
                <div class="absolute inset-0 bg-[#FF7A00] blur-3xl opacity-20"></div>
                <img
                        class="relative z-10 w-full border-4 border-[#2F343C] shadow-[16px_16px_0px_0px_#FF7A00]"
                        src={imageSrc}
                        alt={imageAlt}
                />
            </div>
        </div>

        <div class="md:col-span-6">
      <span class="inline-block px-3 py-1 bg-[#FF7A00] text-white text-[10px] font-black uppercase tracking-widest mb-4">
        {coreLabel}
      </span>

            <h2 class="text-4xl md:text-5xl font-black uppercase leading-tight mb-8">{title}</h2>

            <div class="space-y-4">
                {items.map((item) => (
                        <div class="flex items-start gap-4 p-4 border-b-2 border-zinc-100">
                            <span class="text-[#FF7A00] font-black text-xl italic">{item.number}</span>

                            <div>
                                <h5 class="font-black uppercase">{item.title}</h5>
                                <p class="text-sm text-zinc-500">{item.description}</p>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </div>
</div>