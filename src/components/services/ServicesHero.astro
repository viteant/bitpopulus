---
interface Props {
    title: string
    description: string
    highlight: string
    badgeText: string
    badgeIcon?: string
}

const {
    title,
    description,
    highlight,
    badgeText,
    badgeIcon = 'hub'
} = Astro.props
---

<section class="max-w-7xl mx-auto px-8 mb-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8">
            <h1 class="text-[5rem] md:text-[7rem] leading-[0.9] font-black tracking-tighter uppercase mb-8">
                {title}
            </h1>

            <p class="text-2xl md:text-3xl font-medium max-w-2xl text-[#2F343C]/80 leading-relaxed">
                {description}{' '}
                <span class="text-[#6A00F4] font-extrabold italic">{highlight}</span>
            </p>
        </div>

        <div class="md:col-span-4 flex justify-end">
            <div class="bg-secondary-container p-6 border-4 border-[#2F343C] shadow-[8px_8px_0px_0px_rgba(47,52,60,1)] -rotate-2">
                <span class="material-symbols-outlined text-4xl mb-4">{badgeIcon}</span>
                <p class="font-black text-lg leading-tight uppercase">{badgeText}</p>
            </div>
        </div>
    </div>
</section>