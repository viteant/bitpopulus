---
interface CategoryItem {
    title: string
    description: string
    icon: string
    color: string
}

interface Props {
    items: CategoryItem[]
}

const { items } = Astro.props
---

<section class="max-w-7xl mx-auto px-8 mb-32">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {items.map((item) => (
                <div class="group bg-white p-8 border-4 border-[#2F343C] shadow-[8px_8px_0px_0px_rgba(47,52,60,1)] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all">
                    <div class="w-12 h-12 mb-6 flex items-center justify-center" style={`background-color: ${item.color};`}>
                        <span class="material-symbols-outlined text-white">{item.icon}</span>
                    </div>

                    <h3 class="text-xl font-black uppercase mb-4 leading-tight">{item.title}</h3>
                    <p class="text-sm font-bold text-zinc-500">{item.description}</p>
                </div>
        ))}
    </div>
</section>