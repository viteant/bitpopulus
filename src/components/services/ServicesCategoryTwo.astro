---
interface FeatureItem {
    title: string
    description: string
}

interface Props {
    coreLabel: string
    title: string
    items: FeatureItem[]
    imageSrc: string
    imageAlt: string
}

const { coreLabel, title, items, imageSrc, imageAlt } = Astro.props
---

<div class="bg-[#2F343C] py-32 text-white">
    <div class="max-w-7xl mx-auto px-8 ">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
            <div class="md:col-span-12 mb-12">
        <span class="inline-block px-3 py-1 bg-[#FFD60A] text-[#2F343C] text-[10px] font-black uppercase tracking-widest mb-4">
          {coreLabel}
        </span>

                <h2 class="text-4xl md:text-7xl font-black uppercase leading-tight">{title}</h2>
            </div>

            <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
                {items.map((item) => (
                        <div class="bg-white/5 p-6 border-2 border-white/20 hover:border-[#FFD60A] transition-all">
                            <h4 class="text-xl font-black mb-2 uppercase text-[#FFD60A]">{item.title}</h4>
                            <p class="text-sm opacity-70">{item.description}</p>
                        </div>
                ))}
            </div>

            <div class="md:col-span-4 relative">
                <div class="absolute -top-5 -right-5 md:-top-10 md:-right-10 w-full h-full border-4 border-[#FFD60A] opacity-20"></div>
                <img
                        class="w-full aspect-[3/4] object-cover border-4 border-white shadow-[12px_12px_0px_0px_rgba(255,214,10,1)] grayscale hover:grayscale-0 transition-all duration-500"
                        src={imageSrc}
                        alt={imageAlt}
                />
            </div>
        </div>
    </div>
</div>