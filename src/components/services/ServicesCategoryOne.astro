---
interface FeatureItem {
    label: string
    icon: string
}

interface Props {
    coreLabel: string
    title: string
    description: string
    items: FeatureItem[]
}

const { coreLabel, title, description, items } = Astro.props
---

<div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5 md:sticky md:top-28">
      <span class="inline-block px-3 py-1 bg-[#6A00F4] text-white text-[10px] font-black uppercase tracking-widest mb-4">
        {coreLabel}
      </span>

            <h2 class="text-4xl md:text-5xl font-black uppercase leading-tight mb-6">{title}</h2>
            <div class="h-2 w-24 bg-gradient-to-r from-[#6A00F4] to-[#B5179E] mb-8"></div>
            <p class="text-lg font-medium text-zinc-600">{description}</p>
        </div>

        <div class="md:col-span-7 grid grid-cols-1 gap-4">
            {items.map((item) => (
                    <div class="bg-zinc-50 p-8 border-2 border-[#2F343C] flex justify-between items-center group hover:bg-[#6A00F4] hover:text-white transition-colors cursor-default">
                        <span class="text-2xl font-black uppercase">{item.label}</span>
                        <span class="material-symbols-outlined text-3xl group-hover:rotate-45 transition-transform">
            {item.icon}
          </span>
                    </div>
            ))}
        </div>
    </div>
</div>