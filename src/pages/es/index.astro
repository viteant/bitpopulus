---
import HeroSection from "../../components/sections/HeroSection.astro";
import ProblemsSection from "../../components/sections/ProblemsSection.astro";
import ScalingEngineSection from "../../components/sections/ScalingEngineSection.astro";
import PillarsSection from "../../components/sections/PillarsSection.astro";
import PortfolioSection from "../../components/sections/PortfolioSection.astro";
import InsightsSection from "../../components/sections/InsightsSection.astro";
import FinalCtaSection from "../../components/sections/FinalCtaSection.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import content from "../../content/i18n/home.es.json";

---

<MainLayout lang="es" title={content.seo.title}>
    <HeroSection
            badge={content.hero.badge}
            titleBefore={content.hero.titleBefore}
            titleHighlight={content.hero.titleHighlight}
            titleAfter={content.hero.titleAfter}
            description={content.hero.description}
            primaryCta={content.hero.primaryCta}
            secondaryCta={content.hero.secondaryCta}
            imageSrc={content.hero.imageSrc}
            imageAlt={content.hero.imageAlt}
            floatingTop={content.hero.floatingTop}
            floatingBottom={content.hero.floatingBottom}
    />

    <ProblemsSection
            title={content.problems.title}
            subtitle={content.problems.subtitle}
            badge={content.problems.badge}
            items={content.problems.items}
    />

    <ScalingEngineSection
            title={content.scaling.title}
            subtitle={content.scaling.subtitle}
            badge={content.scaling.badge}
            phases={content.scaling.phases}
    />

    <PillarsSection
            title={content.pillars.title}
            feature={content.pillars.feature}
            brandGrowth={content.pillars.brandGrowth}
            ai={content.pillars.ai}
            engineering={content.pillars.engineering}
    />

    <PortfolioSection
            title={content.portfolio.title}
            titleMuted={content.portfolio.titleMuted}
            viewAllLabel={content.portfolio.viewAllLabel}
            items={content.portfolio.items}
    />

    <InsightsSection
            title={content.insights.title}
            subtitle={content.insights.subtitle}
            items={content.insights.items}
    />

    <FinalCtaSection
            title={content.finalCta.title}
            description={content.finalCta.description}
            ctaLabel={content.finalCta.ctaLabel}
            ctaHref={content.finalCta.ctaHref}
    />
</MainLayout>
